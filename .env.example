OPENAI_API_KEY=dummy
OPENAI_BASE_URL=http://131.159.60.153:3000/inference
MODEL_NAME=google/gemma-4-31B-it
DATABASE_PATH=data/chatbot.db
RAW_MESSAGE_LIMIT=8
RAW_MESSAGE_SPAN_MAX_CHARS=4000
MEMORY_RECALL_BUDGET_TOKENS=8192
GLOBAL_SUMMARY_BUDGET_TOKENS=65536
GLOBAL_SUMMARY_MAX_BUDGET_TOKENS=131072
GLOBAL_SUMMARY_RESERVED_TOKENS=4096
GIST_RETRIEVAL_CANDIDATES=8
DIRECT_RAW_RETRIEVAL_CANDIDATES=12
RAW_SPAN_OVERLAP_THRESHOLD=0.7
ENABLE_RETRIEVAL_QUERY_SIMPLIFICATION=1
MEMORY_UPDATE_BATCH_SIZE=6
MEMORY_UPDATE_POLICY=scheduled
MEMORY_UPDATE_TRIGGER_TOKENS=1000
MEMORY_UPDATE_MAX_INPUT_TOKENS=4000
MEMORY_UPDATE_MAX_MESSAGES=64
MEMORY_RECENT_PROTECTION_TOKENS=1500
MEMORY_REPLAY_TRIGGER_TOKENS=4000
MEMORY_REPLAY_MAX_INPUT_TOKENS=8000
MEMORY_REPLAY_MAX_MESSAGES=128
DEMO_MEMORY_TRACE=0
ORCHESTRATION_MODE=langgraph_demo
ROUTING_MODE=rule
RERANKER_MODE=deterministic

# Gist controls.
CURRENT_CHAT_GIST_GENERATION_ENABLED=0
PREVIOUS_CHAT_GIST_GENERATION_ENABLED=0
PREVIOUS_CHAT_GIST_RETRIEVAL_ENABLED=1
PREVIOUS_CHAT_GIST_EXTRACTOR=deterministic
PREVIOUS_CHAT_GIST_MAX_MESSAGES_PER_GIST=30

# Compatibility seam with one real product implementation.
# Leave as langchain_chroma unless adding another document backend.
DOCUMENT_RETRIEVAL_MODE=langchain_chroma

# Advanced/experimental structured-memory vector index.
# The canonical product path remains STRUCTURED_MEMORY_RETRIEVAL_MODE=sqlite.
LONG_TERM_MEMORY_CHROMA_PERSIST_DIR=data/chroma
LONG_TERM_MEMORY_COLLECTION=long_term_memory

# Advanced/diagnostic reranker options. These are ignored by the canonical
# deterministic reranker unless RERANKER_MODE is changed explicitly.
RERANKER_LLM_TOP_K=10
RERANKER_LLM_MIN_CONFIDENCE=0.55
RERANKER_CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_CROSS_ENCODER_TOP_K=10
RERANKER_CROSS_ENCODER_WEIGHT=0.65
RERANKER_HYBRID_BACKEND=auto
RERANKER_LLM_AMBIGUITY_MARGIN=0.15
RERANKER_LLM_REQUIRE_CROSS_SOURCE_CONFLICT=1
RERANKER_LLM_PROVENANCE_QUERIES=1
STRUCTURED_MEMORY_RETRIEVAL_MODE=sqlite
CHAINLIT_LOCAL_USERNAME=local
CHAINLIT_LOCAL_PASSWORD=local
CHAINLIT_AUTH_SECRET=local-dev-chainlit-secret-change-me
DOCUMENT_CHUNKER=custom
DOCUMENT_CHUNK_SIZE=1000
DOCUMENT_CHUNK_OVERLAP=150
DOCUMENT_TOP_K=8
LANGCHAIN_CHROMA_PERSIST_DIR=data/chroma
LANGCHAIN_CHUNK_SIZE=1000
LANGCHAIN_CHUNK_OVERLAP=150
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
